# Twilio parent account (used to list subaccounts; each subaccount uses SID + this token for Basic auth)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token

# Telnyx: API key (Mission Control → API Keys). Used as Bearer token for REST — NOT the webhook "public key".
TELNYX_API_KEY=KEY0123456789abcdefghijklmnopqrstuvwxyz

# Optional: webhook public key (Ed25519) for verifying Telnyx signatures only — not used by this dashboard's API calls.
# TELNYX_PUBLIC_KEY=

# Or multiple Telnyx keys (comma-separated), optional labels (same count, comma-separated)
# TELNYX_API_KEYS=key1,key2
# TELNYX_TENANT_LABELS=Production,Staging

# Server
PORT=3001

# Cache aggregated API responses (milliseconds). Set 0 to disable.
VISIBILITY_CACHE_TTL_MS=30000
